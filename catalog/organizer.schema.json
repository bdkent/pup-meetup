{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://pup-meetup.dev/catalog/organizer.schema.json",
  "title": "Organizer",
  "description": "A curated meetup organizer and the sources to poll for their events.",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "name", "breeds", "metro", "timezone", "sources"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$",
      "description": "Stable kebab-case identifier. Should match the filename stem."
    },
    "name": { "type": "string", "minLength": 1 },
    "breeds": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
      "description": "Kebab-case breed slugs (e.g. shih-tzu). Use 'all' for general dog meetups."
    },
    "metro": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$",
      "description": "Metro-area slug, e.g. dc, san-francisco."
    },
    "timezone": {
      "type": "string",
      "minLength": 1,
      "description": "IANA timezone (e.g. America/New_York). Used to resolve relative dates and normalize event identity."
    },
    "home_geo": {
      "type": "object",
      "additionalProperties": false,
      "required": ["lat", "lng"],
      "properties": {
        "lat": { "type": "number", "minimum": -90, "maximum": 90 },
        "lng": { "type": "number", "minimum": -180, "maximum": 180 }
      },
      "description": "Optional default coordinates for the organizer's usual area."
    },
    "poll_interval": {
      "enum": ["daily", "weekly"],
      "default": "daily"
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/definitions/source" }
    }
  },
  "definitions": {
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": {
          "enum": ["meetup_ics", "ics", "eventbrite", "rss", "facebook_page", "facebook_group", "instagram"]
        },
        "url": { "type": "string", "minLength": 1 },
        "handle": { "type": "string", "minLength": 1 },
        "enabled": { "type": "boolean", "default": true },
        "notes": { "type": "string" }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "type": { "enum": ["meetup_ics", "ics", "eventbrite", "rss", "facebook_page", "facebook_group"] }
            }
          },
          "then": { "required": ["url"] }
        },
        {
          "if": { "properties": { "type": { "const": "instagram" } } },
          "then": { "required": ["handle"] }
        }
      ]
    }
  }
}
